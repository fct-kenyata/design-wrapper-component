{
  "name": "design-wrapper-component",
  "version": "1.0.0",
  "description": "EaglEye shared design system — shadcn/ui components, Tailwind v4 tokens. Consumed as source via the @design-pattern alias; ships a prebuilt stylesheet so it drops into any host with zero config.",
  "type": "module",
  "main": "index.js",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "components",
    "chartsComponents",
    "hooks",
    "lib",
    "loaders",
    "skeleton",
    "theam",
    "styles",
    "dist",
    "*.jsx",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "playground": "vite",
    "build:css": "tailwindcss -i ./styles/design-system.css -o ./dist/design-system.css --minify",
    "dev:css": "tailwindcss -i ./styles/design-system.css -o ./dist/design-system.css --watch",
    "copy:fonts": "node scripts/copy-fonts.mjs",
    "build": "pnpm build:css && pnpm copy:fonts",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "pnpm": ">=11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide"
    ]
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^2.30.0",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "prop-types": "^15.8.1",
    "radix-ui": "^1.6.0",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
